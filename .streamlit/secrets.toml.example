# Copy to secrets.toml and fill with your R2 credentials. Never commit secrets.toml.
# For Streamlit Cloud: paste the same keys in Settings → Secrets (use format below, one value per line).

R2_ACCESS_KEY = "YOUR_ACCESS_KEY"
R2_SECRET_KEY = "YOUR_SECRET_KEY"
R2_ENDPOINT = "https://ACCOUNTID.r2.cloudflarestorage.com"
R2_BUCKET = "datalake"
R2_REGION = "auto"

# LLM (opcional): DeepSeek (grátis/barato), OpenAI ou OLLAMA_BASE_URL
# DEEPSEEK_API_KEY = "sk-..."
# OPENAI_API_KEY = "sk-..."
# OLLAMA_BASE_URL = "http://localhost:11434/v1"
